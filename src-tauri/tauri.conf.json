{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "cubiq",
  "version": "1.0.2",
  "identifier": "com.cubiq.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm run dev",
    "beforeBuildCommand": "pnpm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Cubiq",
        "width": 1100,
        "height": 720,
        "minWidth": 720,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false,
        "maximized": true
      },
      {
        "label": "quickask",
        "title": "Cubiq Quick Ask",
        "width": 420,
        "height": 550,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "installerHooks": "nsis/hooks.nsh"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../src/assets/lightLogo.png",
      "../src/assets/darkLogo.png"
    ],
    "externalBin": [
      "binaries/cubiq-cli"
    ]
  }
}